PORT=5000
MONGODB_URI=your_mongodb_connection_string

# Google Gemini — required for ID OCR and symptom triage chat
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Model name (gemini-1.5-flash is deprecated and returns 404)
GEMINI_MODEL=gemini-2.5-flash

# OpenAI — optional, only for Voice Agent (Live Audio Triage)
# Must be a PROJECT key from https://platform.openai.com/api-keys (sk-proj-…)
OPENAI_API_KEY=your_openai_api_key_here

# Admin Key
ADMIN_KEY=your_admin_key_here

UPLOAD_DIR=./uploads
